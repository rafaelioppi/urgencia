# Copie para 'sgpur.env' no servidor e preencha os segredos. NUNCA versione o sgpur.env.
# (Spring Boot mapeia estas variaveis para as propriedades correspondentes.)

SPRING_PROFILES_ACTIVE=prod

# Banco Neon (Postgres em Sao Paulo). Use a connection string JDBC do projeto SAUR.
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&prepareThreshold=0
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=__defina_aqui__

# Usuario administrador inicial (definido no primeiro start)
SGPUR_ADMIN_USER=admin
SGPUR_ADMIN_PASSWORD=__defina_uma_senha_forte__

# Diretorio persistente dos anexos (no disco da VM)
APP_ANEXOS_DIR=/opt/sgpur/data/anexos

SERVER_PORT=8080
