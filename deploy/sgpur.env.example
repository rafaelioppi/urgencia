# Copie para 'sgpur.env' no servidor e preencha os segredos. NUNCA versione o sgpur.env.
# (Spring Boot mapeia estas variaveis para as propriedades correspondentes.)

SPRING_PROFILES_ACTIVE=prod

# Banco Neon (Postgres em Sao Paulo). Use a connection string JDBC do projeto SAUR.
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&prepareThreshold=0
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=__defina_aqui__

# Usuario administrador inicial (definido no primeiro start)
SGPUR_ADMIN_USER=admin
SGPUR_ADMIN_PASSWORD=__defina_uma_senha_forte__

# Diretorio persistente dos anexos (no disco da VM)
APP_ANEXOS_DIR=/opt/sgpur/data/anexos

SERVER_PORT=8080

# URL publica do sistema (sem barra final). Vai no link do portal do
# avaliador nos e-mails de convite (EmailTemplateService). Sem isso, o
# default e http://localhost:3000 - quebrado para quem recebe o e-mail.
SGPUR_BASE_URL=https://urgenciarenal.duckdns.org

# SMTP (envio real de e-mail - lembretes, convites, resposta ao solicitante).
# Sem estas variaveis, TODO envio de e-mail falha com "Verifique a
# configuracao de SMTP". Usando Gmail: NAO e a senha normal da conta - crie
# uma "senha de app" em https://myaccount.google.com/apppasswords (exige
# verificacao em duas etapas ativada na conta Google).
SGPUR_MAIL_HOST=smtp.gmail.com
SGPUR_MAIL_PORT=587
SGPUR_MAIL_USER=__seu_email_de_envio@gmail.com__
SGPUR_MAIL_PASS=__senha_de_app_de_16_caracteres__
SGPUR_MAIL_FROM=__seu_email_de_envio@gmail.com__
